# Runtime
NODE_ENV=development
PORT=5000

# CORS
CLIENT_ORIGIN=http://localhost:5173
CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
# Leave MONGO_URI empty in local development to use the MongoDB memory server.
# Set this to a MongoDB Atlas mongodb+srv:// URI in production.
MONGO_URI=

# Auth
JWT_SECRET=replace-with-a-long-random-production-secret
JWT_EXPIRES_IN=7d

# Seed behavior
AUTO_SEED=true
